# =========================
# Project
# =========================
PROJECT_NAME=nike-ai-dataops-pipeline
ENVIRONMENT=local
LOG_LEVEL=INFO

# =========================
# AWS
# =========================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your_s3_bucket_name

# =========================
# AWS RDS PostgreSQL
# =========================
RDS_HOST=your_rds_endpoint
RDS_PORT=5432
RDS_DB=nike_dataops
RDS_USER=etl_user
RDS_PASSWORD=your_rds_password

# Optional readonly user for Streamlit Text-to-SQL
RDS_READONLY_USER=ui_readonly_user
RDS_READONLY_PASSWORD=your_readonly_password

# =========================
# Local Postgres for Docker/Airflow metadata
# =========================
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =========================
# Gemini AI
# =========================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# =========================
# Telegram Alerting
# =========================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# =========================
# Pipeline SLA Config
# =========================
PIPELINE_NAME=nike_omni_inventory_etl
SLA_LIMIT_MINUTES=240
DEFAULT_CLUSTER_NODES=4
SCALED_CLUSTER_NODES=10

# =========================
# S3 Paths
# =========================
S3_RAW_PREFIX=raw/nike/events
S3_QUARANTINE_PREFIX=quarantine/nike/events
S3_PROCESSED_PREFIX=processed/nike/events

# =========================
# AWS Free Tier Tracking
# =========================
S3_FREE_TIER_PUT_LIMIT=2000
S3_FREE_TIER_GET_LIMIT=20000
S3_STANDARD_STORAGE_COST_PER_GB_MONTH=0.023
